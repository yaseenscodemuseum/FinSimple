# ── AI Provider Keys ──
# Set one or more keys. FinSimple tries them in this order:
# Claude → Gemini → OpenAI → OpenRouter
# If one fails, it automatically falls back to the next.

# Anthropic / Claude
ANTHROPIC_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# OpenAI
OPENAI_API_KEY=

# OpenRouter (free models, no credit card needed)
OPENROUTER_API_KEY=

# ── Optional overrides ──

# Force a specific provider (skips the failback chain):
# AI_PROVIDER=anthropic

# Override the default model for your provider:
# AI_MODEL=claude-sonnet-4-20250514

# ── Rate limiting (Upstash Redis) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
